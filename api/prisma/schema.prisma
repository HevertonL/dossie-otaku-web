// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dossiers  Dossier[]

  @@map("users")
}

model Dossier {
  id         String   @id @default(uuid())
  userId     String
  animeId    Int
  rating     Int      // Nota de 1 a 5
  text       String   // Renomeado de 'review' para 'text'
  hasSpoiler Boolean  @default(false) // Novo campo exigido na US
  status     String?  // Mantido como opcional
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id])

  @@map("dossiers")
}